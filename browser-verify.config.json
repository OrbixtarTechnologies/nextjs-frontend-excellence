{
  "baseUrl": "http://localhost:3000",
  "headless": true,
  "timeoutMs": 30000,
  "selectorTimeoutMs": 5000,
  "outputDir": "artifacts/browser-verification",
  "baselineDir": "artifacts/browser-baseline",
  "requireBaselineMatch": false,
  "migrateCommand": "npm run db:migrate",
  "tempUserCommand": "npm run db:create-temp-user",
  "auth": {
    "mode": "session-cookie",
    "cookieEnv": "LOCAL_SESSION_COOKIE",
    "cookieName": "session",
    "domain": "localhost"
  },
  "viewports": [
    { "name": "desktop", "width": 1440, "height": 900 },
    { "name": "tablet", "width": 1024, "height": 768 },
    { "name": "mobile", "width": 390, "height": 844 }
  ],
  "routes": [
    {
      "path": "/",
      "requiredSelectors": ["main", "header"],
      "requiredText": ["Welcome"]
    },
    {
      "path": "/dashboard",
      "requiredSelectors": ["[data-testid='dashboard-shell']", "nav"],
      "requiredText": ["Dashboard"]
    }
  ]
}
